# Скопируйте в `.env` в корне репозитория для `docker compose up`.
# Обязательные переменные для сервиса `api` (см. docker-compose.yml).

JWT_SECRET=change-me-very-long-random-secret-at-least-32-chars
ADMIN_LOGIN=lk-admin
ADMIN_PASSWORD=change-me-strong-password

# Origin фронта в браузере (через запятую). Для стека compose по умолчанию:
# CORS_ORIGINS=http://localhost:4173,http://127.0.0.1:4173

# Сборка фронта: относительный URL — nginx проксирует на контейнер `api`.
# VITE_API_URL=/api

# Необязательно: пробросьте в сервис `api` через docker-compose.override.yml или расширьте
# секцию environment в docker-compose.yml — см. backend/.env.example
# RATE_LIMIT_LOGIN_MAX=50
# RATE_LIMIT_API_MAX=300
# RATE_LIMIT_EXPORT_MAX=60
# OUTBOUND_WEBHOOK_URL=
# WEBHOOK_TRIGGER_SECRET=
