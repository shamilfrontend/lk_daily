PORT=4000
# Очередь использует транзакции MongoDB — нужен replica set (standalone не подойдёт).
# Пример одноузлового rs0 на localhost:
# MONGO_URI=mongodb://127.0.0.1:27017/lk-daily?replicaSet=rs0&directConnection=true
MONGO_URI=mongodb://127.0.0.1:27017/lk-daily
JWT_SECRET=change-me-very-long-random-secret-at-least-32-chars
ADMIN_LOGIN=lk-admin
ADMIN_PASSWORD=change-me-strong-password

# Список origin фронта через запятую. Пусто = разрешены все (удобно для dev).
# CORS_ORIGINS=http://localhost:5173

# Лимит запросов на POST /api/auth/login за 15 минут на один IP
# RATE_LIMIT_LOGIN_MAX=50

# Общий лимит запросов к /api за 15 минут на один IP
# RATE_LIMIT_API_MAX=300

# Лимит для публичных экспортов GET /api/history/export/csv и /api/queue/upcoming/export/* за 15 минут на IP
# RATE_LIMIT_EXPORT_MAX=60

# Исходящий webhook (например Slack Incoming Webhook URL). Без него POST /api/hooks/notify-today вернёт 503.
# OUTBOUND_WEBHOOK_URL=https://hooks.slack.com/services/...

# Секрет для вызова POST /api/hooks/notify-today (заголовок Authorization: Bearer … или X-Lk-Daily-Secret).
# Пусто — эндпоинт отключён (ответ 404).
# WEBHOOK_TRIGGER_SECRET=long-random-string
