PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/lk-daily
JWT_SECRET=dev-secret-change-me
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123

# Список origin фронта через запятую. Пусто = разрешены все (удобно для dev).
# CORS_ORIGINS=http://localhost:5173

# Лимит запросов на POST /api/auth/login за 15 минут на один IP
# RATE_LIMIT_LOGIN_MAX=50

# Исходящий webhook (например Slack Incoming Webhook URL). Без него POST /api/hooks/notify-today вернёт 503.
# OUTBOUND_WEBHOOK_URL=https://hooks.slack.com/services/...

# Секрет для вызова POST /api/hooks/notify-today (заголовок Authorization: Bearer … или X-Lk-Daily-Secret).
# Пусто — эндпоинт отключён (ответ 404).
# WEBHOOK_TRIGGER_SECRET=long-random-string
