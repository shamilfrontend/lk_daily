{
  "name": "lk-daily-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:e2e": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,vue}\"",
    "format": "prettier --write \"src/**/*.{ts,vue,scss,css,json}\" && eslint \"src/**/*.{ts,vue}\" --fix && prettier --write \"src/**/*.{ts,vue,scss,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,scss,css,json}\" && eslint \"src/**/*.{ts,vue}\"",
    "e2e": "playwright install chromium && playwright test",
    "e2e:install": "playwright install chromium",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@kyvg/vue3-notification": "^3.4.2",
    "@vuepic/vue-datepicker": "^12.1.0",
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.50.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^9.18.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "sass": "^1.83.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vite": "^6.0.7"
  }
}
